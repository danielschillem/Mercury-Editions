APP_NAME="Mercury Editions"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
# Port 1025 = Mailpit (dev). SMTP production : 587 (STARTTLS) ou 465 (SSL).
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contact@mercury-editions.bf"
MAIL_FROM_NAME="${APP_NAME}"

MERCURY_EDITORIAL_EMAIL="manuscrits@mercury-editions.bf"

ORANGE_OM_SIMULATE=true  # Mettre false uniquement quand les credentials prod sont renseignés
ORANGE_OM_ENV=test
ORANGE_COUNTRY_CODE=226
ORANGE_OM_URL_PROD=https://apiom.orange.bf/
ORANGE_OM_URL_TEST=https://testom.orange.bf/
ORANGE_OM_MERCHANT_MSISDN=
ORANGE_OM_API_USERNAME=
ORANGE_OM_API_PASSWORD=
ORANGE_OM_PROVIDER=101
ORANGE_OM_PROVIDER2=101
ORANGE_OM_PAYID=12
ORANGE_OM_PAYID2=12

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CORS — origines autorisées (virgule-séparées). En prod : https://mercury-editions.bf
CORS_ALLOWED_ORIGINS="${APP_URL}"
